set -euo pipefail

# ─────────────────────────────────────────────────────────────────────────────
# CONFIG
# ─────────────────────────────────────────────────────────────────────────────
NVIM_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/nvim"
SHARINGAN_DIR="${HOME}/.local/share/sharingan"
SHARINGAN_DATA="${SHARINGAN_DIR}/data"
CACHE_DIR="${HOME}/.cache/sharingan"
LAZY_LOCK="${NVIM_CONFIG_DIR}/lazy-lock.json"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
ORANGE='\033[0;33m'
PINK='\033[0;38;5;205m'
BG_DARK='\033[48;2;30;30;46m'
BG_CARD='\033[48;2;40;44;56m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# Spinner
SPINNER_CHARS=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
spin_idx=0

# ─────────────────────────────────────────────────────────────────────────────
# UTILITIES
# ─────────────────────────────────────────────────────────────────────────────
log() { printf "${BG_DARK}  %s${RESET}\n" "$*"; }
info() { printf "${BG_DARK}  ${BLUE}ℹ${RESET} %s${RESET}\n" "$*"; }
success() { printf "${BG_DARK}  ${GREEN}✓${RESET} %s${RESET}\n" "$*"; }
warn() { printf "${BG_DARK}  ${YELLOW}⚠${RESET} %s${RESET}\n" "$*"; }
error() { printf "${BG_DARK}  ${RED}✗${RESET} %s${RESET}\n" "$*"; }

spinner_start() {
    spin_idx=0
}
spinner_update() {
    printf "\r${BG_DARK}  ${CYAN}%s${RESET} %s..." "${SPINNER_CHARS[$spin_idx]}" "$*"
    spin_idx=$(( (spin_idx + 1) % ${#SPINNER_CHARS[@]} ))
}
spinner_stop() {
    printf "\r${BG_DARK}  ${GREEN}✓${RESET} %s\n" "$*"
}

draw_box() {
    local title="$1"
    local width=60
    local content=("${@:2}")
    
    echo -e "${BG_CARD}  ┌$(printf '─%.0s' $(seq 1 $width))┐"
    printf "${BG_CARD}  │${BOLD} %-${width}s │\n" "$title"
    echo -e "${BG_CARD}  ├$(printf '─%.0s' $(seq 1 $width))┤"
    for line in "${content[@]}"; do
        printf "${BG_CARD}  │ %-${width}s │\n" "${line:0:$width}"
    done
    echo -e "${BG_CARD}  └$(printf '─%.0s' $(seq 1 $width))┘${RESET}"
}

progress_bar() {
    local current=$1
    local total=$2
    local width=40
    local filled=$(( current * width / total ))
    local percent=$(( current * 100 / total ))
    
    printf "${BG_DARK}  [${GREEN}%${filled}s${DIM}%${((width - filled))}s${RESET}] ${CYAN}%3d%%${RESET}\n" \
        "" "" "$percent"
}

ask() {
    echo -e "\n${BG_CARD}${YELLOW}[?]${RESET} ${CYAN}$*${RESET}"
    echo -ne "${BG_CARD}[${GREEN}y${RESET}/${RED}n${RESET}]: ${BOLD}"
    read -r answer
    echo -ne "${RESET}"
    [[ "${answer,,}" =~ ^(y|yes)$ ]]
}


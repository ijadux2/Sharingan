# ─────────────────────────────────────────────────────────────────────────────
# COMMANDS
# ─────────────────────────────────────────────────────────────────────────────
cmd_update() {
    local plugin="${1:-}"
    local force="${FORCE:-false}"
    
    if [[ -n "$plugin" ]]; then
        if [[ "$plugin" == "tangle" ]]; then
            cmd_update_tangle
        else
            update_plugin "$plugin"
        fi
    else
        update_all
    fi
}

update_all() {
    info "Syncing all plugins..."
    spinner_start
    
    if command -v nvim &>/dev/null; then
        nvim --headless "+Lazy! sync" +qa 2>&1 | while IFS= read -r line; do
            spinner_update "Syncing"
        done
        spinner_stop "All plugins updated!"
    else
        error "Neovim not found. Install it first."
        exit 1
    fi
}

update_plugin() {
    local plugin="$1"
    info "Updating ${CYAN}$plugin${RESET}..."
    
    if command -v nvim &>/dev/null; then
        nvim --headless "+Lazy! load $plugin" +qa 2>&1 || true
        success "Plugin '${plugin}' updated!"
    else
        error "Neovim not found."
        exit 1
    fi
}

update_tangle() {
    if [[ -f "$LAZY_LOCK" ]]; then
        success "Config tangle is up to date"
    else
        warn "No lazy-lock.json found. Run 'sharingan sync' first."
    fi
}

cmd_reset() {
    if ! "${FORCE:-false}" && ! ask "Reset your Neovim config to latest git?"; then
        info "Aborted."
        exit 0
    fi
    
    if [[ -d "$NVIM_CONFIG_DIR/.git" ]]; then
        info "Pulling latest from git..."
        git -C "$NVIM_CONFIG_DIR" pull origin main 2>&1 || true
        success "Config reset complete!"
    else
        warn "Config is not a git repository."
        info "Use 'sharingan update' to clone from a remote."
    fi
}

cmd_remove_config() {
    if ! "${FORCE:-false}" && ! ask "Completely remove your Neovim config? This cannot be undone!"; then
        info "Aborted."
        exit 0
    fi
    
    if [[ -d "$NVIM_CONFIG_DIR" ]]; then
        rm -rf "$NVIM_CONFIG_DIR"
        success "Neovim config removed."
    else
        warn "Config directory does not exist."
    fi
}

cmd_list() {
    if [[ ! -f "$LAZY_LOCK" ]]; then
        error "No lazy-lock.json found. Run 'sharingan sync' first."
        exit 1
    fi
    
    echo -e "${BG_DARK}\n  ${CYAN}${BOLD}INSTALLED PLUGINS${RESET}"
    echo -e "${BG_DARK}  ${DIM}════════════════════════════════════════════════════════════════${RESET}"
    
    local count=0
    while IFS= read -r line; do
        if [[ "$line" =~ ^[[:space:]]*\"([^\"]+)\" ]]; then
            count=$((count + 1))
            local name="${BASH_REMATCH[1]}"
            local url="https://github.com/$name"
            echo -e "${BG_DARK}  ${GREEN}$count.${RESET} ${CYAN}$name${RESET}"
            echo -e "${BG_DARK}     ${DIM}↳${RESET} ${PURPLE}$url${RESET}"
        fi
    done < "$LAZY_LOCK"
    
    echo -e "${BG_DARK}\n  ${DIM}Total: $count plugins${RESET}\n${RESET}"
}

cmd_clean() {
    info "Cleaning unused plugins..."
    
    if command -v nvim &>/dev/null; then
        nvim --headless "+Lazy! clean" +qa 2>&1 || true
        success "Cleanup complete!"
    else
        error "Neovim not found."
        exit 1
    fi
}

cmd_sync() {
    info "Syncing plugins..."
    spinner_start
    
    if command -v nvim &>/dev/null; then
        nvim --headless "+Lazy! sync" +qa 2>&1 | while IFS= read -r line; do
            spinner_update "Syncing"
        done
        spinner_stop "Plugins synced!"
    else
        error "Neovim not found."
        exit 1
    fi
}

cmd_search() {
    local query="$1"
    
    if ! command -v curl &>/dev/null; then
        error "curl is required for search."
        exit 1
    fi
    
    info "Searching for '$query'..."
    echo ""
    
    local results
    results=$(curl -s "https://registry.npmjs.org/-/v1/search?text=$query&size=10" 2>/dev/null) || {
        error "Search failed. Check your internet connection."
        exit 1
    }
    
    echo "$results" | jq -r '.objects[] | "\(.package.name)\n  \(.package.description // "No description")\n  Version: \(.package.version)\n"' 2>/dev/null || {
        echo "$results"
    }
}

cmd_info() {
    local plugin="$1"
    
    if [[ ! -f "$LAZY_LOCK" ]]; then
        error "No lazy-lock.json found. Run 'sharingan sync' first."
        exit 1
    fi
    
    local entry
    entry=$(grep -A5 "\"$plugin\"" "$LAZY_LOCK" 2>/dev/null | head -10) || {
        error "Plugin '$plugin' not found."
        exit 1
    }
    
    draw_box "Plugin Info" "$plugin" "Status: Installed" "$entry"
}

cmd_doctor() {
    echo -e "${BG_DARK}\n  ${CYAN}${BOLD}SYSTEM CHECK${RESET}"
    echo -e "${BG_DARK}  ${DIM}════════════════════════════════════════════════════════════════${RESET}"
    
    # Check git
    if command -v git &>/dev/null; then
        echo -e "${BG_DARK}  ${GREEN}✓${RESET} Git is installed ($(git --version | cut -d' ' -f3))"
    else
        echo -e "${BG_DARK}  ${RED}✗${RESET} Git is not installed"
        echo -e "${BG_DARK}       ${DIM}→${RESET} ${CYAN}Install: sudo apt install git (Debian/Ubuntu)${RESET}"
    fi
    
    # Check neovim
    if command -v nvim &>/dev/null; then
        local version
        version=$(nvim --version | head -1 | cut -d' ' -f2)
        echo -e "${BG_DARK}  ${GREEN}✓${RESET} Neovim is installed ($version)"
    else
        echo -e "${BG_DARK}  ${RED}✗${RESET} Neovim is not installed"
        echo -e "${BG_DARK}       ${DIM}→${RESET} ${CYAN}Install: https://github.com/neovim/neovim/releases${RESET}"
    fi
    
    # Check config
    if [[ -d "$NVIM_CONFIG_DIR" ]]; then
        echo -e "${BG_DARK}  ${GREEN}✓${RESET} Neovim config exists at $NVIM_CONFIG_DIR"
    else
        echo -e "${BG_DARK}  ${YELLOW}⚠${RESET} Neovim config not found"
        echo -e "${BG_DARK}       ${DIM}→${RESET} ${CYAN}Run 'sharingan sync' to set up${RESET}"
    fi
    
    # Check lazy-lock
    if [[ -f "$LAZY_LOCK" ]]; then
        echo -e "${BG_DARK}  ${GREEN}✓${RESET} lazy-lock.json exists"
    else
        echo -e "${BG_DARK}  ${YELLOW}⚠${RESET} lazy-lock.json not found"
        echo -e "${BG_DARK}       ${DIM}→${RESET} ${CYAN}Run 'sharingan sync' to generate${RESET}"
    fi
    
    echo -e "${BG_DARK}\n${RESET}"
}

# ─────────────────────────────────────────────────────────────────────────────
# MAIN
# ─────────────────────────────────────────────────────────────────────────────
main() {
    local cmd="${1:-help}"
    local force=false
    local verbose=false
    
    shift 2>/dev/null || true
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f|--force) force=true; shift ;;
            -v|--verbose) verbose=true; shift ;;
            *) break ;;
        esac
    done
    
    export FORCE="$force"
    export VERBOSE="$verbose"
    
    case "$cmd" in
        update)
            cmd_update "${1:-}"
            ;;
        reset)
            cmd_reset
            ;;
        remove-config)
            cmd_remove_config
            ;;
        list)
            cmd_list
            ;;
        clean)
            cmd_clean
            ;;
        sync)
            cmd_sync
            ;;
        search)
            if [[ -z "${1:-}" ]]; then
                error "Usage: sharingan search <query>"
                exit 1
            fi
            cmd_search "$1"
            ;;
        info)
            if [[ -z "${1:-}" ]]; then
                error "Usage: sharingan info <plugin>"
                exit 1
            fi
            cmd_info "$1"
            ;;
        doctor)
            cmd_doctor
            ;;
        help|--help|-h|"")
            welcome
            help
            ;;
        *)
            error "Unknown command: $cmd"
            echo ""
            help
            exit 1
            ;;
    esac
}

main "$@"
